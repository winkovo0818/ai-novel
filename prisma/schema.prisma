// Prisma schema — Onboarding MVP
// 字段定义来源：docs/contracts.md §6（不要在此处偏离）
//
// 核心表：
//   OnboardingSession  向导会话与中间结果（含服务端重摆计数，决策 D-04）
//   Novel              finalize 后正式创建的小说项目（user_id 可空，决策 D-03）
//   BibleDraft         保存生成完成或编辑后的 Bible 草稿
//   ChapterDraft       主编辑器中的章节草稿（阶段 2）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model OnboardingSession {
  id                  String   @id @default(uuid())
  user_id             String?
  genre_main          String
  genre_sub           String
  title               String?
  logline             String?
  logline_suggestions Json?
  questions           Json?
  answers             Json?
  bible_draft         Json?
  regeneration_count  Int      @default(0)
  status              String   @default("active")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([user_id])
  @@index([status])
}

model Novel {
  id         String   @id @default(uuid())
  user_id    String?
  title      String
  profile    Json
  session_id String?
  created_at DateTime @default(now())

  bible BibleDraft?
  chapters ChapterDraft[]

  @@index([user_id])
}

model BibleDraft {
  id         String   @id @default(uuid())
  novel_id   String   @unique
  novel      Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  content    Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ChapterDraft {
  id            String   @id @default(uuid())
  novel_id      String
  novel         Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  chapter_index Int
  title         String
  content       String   @default("")
  status        String   @default("draft")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  versions ChapterVersion[]
  summary  ChapterSummary?

  @@unique([novel_id, chapter_index])
  @@index([novel_id])
  @@index([status])
}

model ChapterSummary {
  id          String   @id @default(uuid())
  chapter_id  String   @unique
  chapter     ChapterDraft @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  summary     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model LlmModel {
  id           String   @id @default(uuid())
  name         String
  provider     String   @default("deepseek")
  base_url     String
  api_key      String
  model        String
  is_default   Boolean  @default(false)
  is_enabled   Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([provider, model])
}

model ChapterVersion {
  id           String   @id @default(uuid())
  chapter_id   String
  chapter      ChapterDraft @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  title        String
  content      String
  content_hash String?
  status       String   @default("draft")
  source       String   @default("manual")
  created_at   DateTime @default(now())

  @@index([chapter_id])
  @@index([created_at])
  @@index([chapter_id, content_hash])
}
