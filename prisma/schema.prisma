// Prisma schema — Onboarding MVP
// 字段定义来源：docs/contracts.md §6（不要在此处偏离）
//
// 核心表：
//   OnboardingSession  向导会话与中间结果（含服务端重摆计数，决策 D-04）
//   Novel              finalize 后正式创建的小说项目（user_id 可空，决策 D-03）
//   BibleDraft         保存生成完成或编辑后的 Bible 草稿
//   ChapterDraft       主编辑器中的章节草稿（阶段 2）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model OnboardingSession {
  id                  String   @id @default(uuid())
  user_id             String?
  genre_main          String
  genre_sub           String
  title               String?
  logline             String?
  logline_suggestions Json?
  questions           Json?
  answers             Json?
  bible_draft         Json?
  regeneration_count  Int      @default(0)
  status              String   @default("active")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([user_id])
  @@index([status])
}

model Novel {
  id         String   @id @default(uuid())
  user_id    String?
  title      String
  profile    Json
  session_id String?
  created_at DateTime @default(now())

  bible BibleDraft?
  chapters ChapterDraft[]
  volume_summaries VolumeSummary[]
  novel_summary NovelSummary?
  memory_chunks MemoryChunk[]

  @@index([user_id])
  @@unique([session_id])
}

model BibleDraft {
  id         String   @id @default(uuid())
  novel_id   String   @unique
  novel      Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  content    Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ChapterDraft {
  id            String   @id @default(uuid())
  novel_id      String
  novel         Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  chapter_index Int
  title         String
  content       String   @default("")
  status        String   @default("draft")
  /// Optional per-chapter word target. Null means no target — UI hides the
  /// progress affordance entirely. When set, the editor shows a target ring.
  target_words  Int?
  /// Optimistic-lock counter. Bumped on every PATCH and on restore so two
  /// tabs / devices editing the same chapter detect conflicts instead of
  /// silently overwriting each other (see /api/chapters/:id PATCH).
  version       Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  versions ChapterVersion[]
  summary  ChapterSummary?

  @@unique([novel_id, chapter_index])
  @@index([novel_id])
  @@index([status])
}

model ChapterSummary {
  id          String   @id @default(uuid())
  chapter_id  String   @unique
  chapter     ChapterDraft @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  summary     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model LlmModel {
  id           String   @id @default(uuid())
  name         String
  provider     String   @default("deepseek")
  base_url     String
  api_key      String
  model        String
  is_default   Boolean  @default(false)
  is_enabled   Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([provider, model])
}

/// DB-driven role grants. Composite PK (user_id, role) lets a user hold
/// multiple roles without schema churn — Phase A only fills 'admin', later
/// phases (e.g. 'embedding_admin') just insert new rows. user_id is not a
/// FK because Supabase auth.users lives outside Prisma; deletes there must
/// be paired with a manual cleanup of dangling rows.
model UserRole {
  user_id    String
  role       String
  granted_by String?
  created_at DateTime @default(now())

  @@id([user_id, role])
  @@index([role])
}

model ChapterVersion {
  id           String   @id @default(uuid())
  chapter_id   String
  chapter      ChapterDraft @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  title        String
  content      String
  content_hash String?
  status       String   @default("draft")
  source       String   @default("manual")
  created_at   DateTime @default(now())

  @@index([chapter_id])
  @@index([created_at])
  @@index([chapter_id, content_hash])
}

model VolumeSummary {
  id              String   @id @default(uuid())
  novel_id        String
  novel           Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  volume_index    Int
  summary         String
  covered_chapters String[]
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([novel_id, volume_index])
  @@index([novel_id])
}

model NovelSummary {
  id         String   @id @default(uuid())
  novel_id   String   @unique
  novel      Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  summary    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model MemoryChunk {
  id           String   @id @default(uuid())
  novel_id     String
  novel        Novel    @relation(fields: [novel_id], references: [id], onDelete: Cascade)
  chapter_id   String?
  chunk_type   String   @default("scene")
  text         String
  embedding    Unsupported("vector(1024)")?
  content_hash String?
  metadata     Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([novel_id])
  @@index([novel_id, chunk_type])
  @@index([chapter_id])
}

model LlmUsage {
  id          String   @id @default(uuid())
  user_id     String
  novel_id    String?
  route       String
  agent       String?
  model       String
  token_in    Int      @default(0)
  token_out   Int      @default(0)
  cost_cny    Float    @default(0)
  status      String   @default("ok")
  error_code  String?
  /// Round-trip latency in milliseconds. Populated by the LLM client.
  /// Null on rows that pre-date the column.
  took_ms     Int?
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([novel_id])
  @@index([novel_id, created_at])
  @@index([route])
}

/// Background job queue for fire-and-forget memory work
/// (chapter summarize, chunk index, tiered-summary refresh).
/// Persisting these turns silent failures into observable rows
/// the UI can surface and the user can retry.
model BackgroundJob {
  id          String    @id @default(uuid())
  novel_id    String
  type        String    // summarize_chapter | index_chapter | refresh_summaries
  payload     Json
  status      String    @default("pending") // pending | running | done | failed
  attempts    Int       @default(0)
  last_error  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  started_at  DateTime?
  finished_at DateTime?

  @@index([novel_id, status])
  @@index([status, created_at])
  @@index([type, status])
}
