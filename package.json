{
  "name": "ai-novel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:deploy": "dotenv -e .env -- prisma migrate deploy",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force",
    "db:smoke": "dotenv -e .env -- tsx scripts/db-smoke-test.ts",
    "smoke:onboarding": "dotenv -e .env -- tsx scripts/onboarding-api-smoke.ts",
    "prompt:bible": "tsx scripts/test-bible-prompt.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "next": "^15.1.6",
    "next-intl": "^4.11.0",
    "partial-json": "^0.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
