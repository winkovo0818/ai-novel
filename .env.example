# PostgreSQL
# 默认使用本地 Docker PostgreSQL；如果不用 Docker，也可以替换为 Supabase 提供的 PostgreSQL 连接串。
# 使用 Supabase 时，Prisma 推荐 DATABASE_URL 和 DIRECT_URL 都用 direct connection。
# 如果必须使用 pooler，需确认连接串支持 Prisma prepared statements。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_novel
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ai_novel

# DeepSeek-V3（OpenAI 兼容协议）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 本地开发 / smoke 可开启 mock，避免真实调用 DeepSeek。
# LLM_MOCK=1

# 当前应用对外访问地址
NEXT_PUBLIC_APP_URL=http://localhost:3000
