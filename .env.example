DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
# DeepSeek-V3（OpenAI 兼容协议）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LLM 模型配置加密密钥（至少 32 字符）
MODEL_KEY_ENCRYPTION_SECRET=change-me-to-a-random-32-char-secret-key

# 本地开发 / smoke 可开启 mock，避免真实调用 DeepSeek。
# LLM_MOCK=1

# Supabase Auth / SSR client
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase 服务端密钥 (server-only)。/admin/users 通过 supabase.auth.admin
# 列出用户与查询单用户。绕过 RLS — 千万不要暴露给客户端。
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 管理员 allowlist。DB user_roles 表是主权限源，未命中时 fallback 到这里。
# 留作生产逃生口：DB 删空 / 最后一个 admin 被误删都能从这里恢复访问。
# ADMIN_USER_IDS=uuid-1,uuid-2
# ADMIN_EMAILS=admin@example.com,ops@example.com

# 当前应用对外访问地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 内容审核失败模式：allow（开发）、block（生产）、review
# MODERATION_FAILURE_MODE=allow

# LLM 用量配额限制
DAILY_COST_LIMIT_CNY=50
MONTHLY_COST_LIMIT_CNY=500
DAILY_CALL_LIMIT=200
MONTHLY_CALL_LIMIT=5000

# 配额检查异常时的策略：allow（开发）、block（生产，默认）
# QUOTA_FAILURE_MODE=allow

# 速率限制后端：
# - 缺省（不设）使用进程内 Map（单实例 OK，多副本会泄漏窗口）
# - redis：使用 Upstash Redis REST API；需要下面两个变量都配齐
# RATE_LIMIT_STORE=redis
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 本地开发的 docker-compose Postgres 凭据（生产请用 Supabase / 托管 DB）
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=ai_novel
