DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_novel?schema=public
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_novel?schema=public
# DeepSeek-V3（OpenAI 兼容协议）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LLM 模型配置加密密钥（至少 32 字符）
MODEL_KEY_ENCRYPTION_SECRET=change-me-to-a-random-32-char-secret-key

# 本地开发 / smoke 可开启 mock，避免真实调用 DeepSeek。
# LLM_MOCK=1

# Auth.js session secret. 生产环境必填；用 `openssl rand -base64 32` 生成。
AUTH_SECRET=replace-with-a-long-random-auth-secret

# 管理员 allowlist。DB user_roles 表是主权限源，未命中时 fallback 到这里。
# 留作生产逃生口：DB 删空 / 最后一个 admin 被误删都能从这里恢复访问。
# ADMIN_USER_IDS=uuid-1,uuid-2
# ADMIN_EMAILS=admin@example.com,ops@example.com

# 当前应用对外访问地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 内容审核失败模式：allow（开发）、block（生产）、review
# MODERATION_FAILURE_MODE=allow

# LLM 用量配额限制
DAILY_COST_LIMIT_CNY=50
MONTHLY_COST_LIMIT_CNY=500
DAILY_CALL_LIMIT=200
MONTHLY_CALL_LIMIT=5000
SINGLE_REQUEST_COST_LIMIT_CNY=10
# 粗略成本预估：中文约 1-2 字/token，默认按 2 字/token 和 4096 输出 token 预算估算。
# LLM_COST_ESTIMATE_CHARS_PER_TOKEN=2
# LLM_COST_ESTIMATE_OUTPUT_TOKENS=4096

# 配额检查异常时的策略：allow（开发）、block（生产，默认）
# QUOTA_FAILURE_MODE=allow

# 速率限制后端：
# - 缺省（不设）使用进程内 Map（单实例 OK，多副本会泄漏窗口）
# - redis：使用 Upstash Redis REST API；需要下面两个变量都配齐
# RATE_LIMIT_STORE=redis
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Prometheus 指标端点 /api/metrics 的鉴权 token（HTTP Bearer）。
# 未设时端点返回 503（拒绝默认裸奔）。在 Prometheus scrape 配置里写同样
# 的 bearer_token 即可。建议 ≥ 32 字符随机串。
# METRICS_TOKEN=replace-with-a-long-random-string

# Sentry server-side error reporting. 未设时不上报；设为项目 DSN 后，
# Next.js onRequestError 会通过无 SDK envelope 上报未处理请求异常。
# SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/0000000
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=

# Vercel Cron 调用 /api/cron/* 时使用的 Bearer token。未设时 cron 端点
# 返回 503。建议 ≥ 32 字符随机串。
# CRON_SECRET=replace-with-a-long-random-string

# DraftSession 续传草稿保留时长，默认 30 天；超龄行由每日 cron 删除。
# DRAFT_SESSION_RETENTION_MS=2592000000

# 后台 jobs worker。Docker Compose 的 worker 服务会运行 `npm run jobs:worker`。
# JOBS_WORKER_POLL_MS=2000
# JOBS_WORKER_SWEEP_MS=60000
# JOBS_WORKER_TYPES=summarize_chapter,index_chapter,refresh_summaries
# JOBS_WORKER_NOVEL_ID=

# RAG 检索是否参考读者反馈（MemoryFeedback）。默认开启：被标"有用"的记忆块
# 排名上升，被标"无关"的下降，标记 2 次及以上"无关"的块直接从候选中剔除。
# 设为 0 可回退到纯向量 + 时间衰减排序（用于 A/B 对比 feedback 效果）。
# RETRIEVAL_USE_FEEDBACK=1

# 上线前备份检查。生产建议由备份任务写入最新成功时间，再运行
# `npm run backup:check` 验证 DB 连接、关键表数量、最近写入和备份新鲜度。
# BACKUP_LAST_SUCCESS_AT=2026-05-28T00:00:00.000Z
# BACKUP_CHECK_MAX_BACKUP_AGE_HOURS=26
# BACKUP_CHECK_REQUIRE_BACKUP=1

# 本地开发的 docker-compose Postgres 凭据（生产请用托管 Postgres）
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=ai_novel
